{
    "name": "@plurnk/plurnk-mimetypes-grammar-zig",
    "version": "0.1.0",
    "description": "Pre-built tree-sitter-zig WASM grammar for @plurnk/plurnk-mimetypes.",
    "type": "module",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=25"
    },
    "exports": {
        ".": {
            "default": "./index.js"
        },
        "./package.json": "./package.json",
        "./zig.wasm": "./zig.wasm"
    },
    "files": [
        "zig.wasm",
        ".grammar-pin",
        "index.js",
        "README.md"
    ],
    "scripts": {
        "build:wasm": "node scripts/build-wasm.mjs",
        "verify:wasm": "node scripts/verify-wasm.mjs",
        "update:pin": "node scripts/update-pin.mjs",
        "update": "npm run update:pin && npm run build:wasm && npm run verify:wasm"
    },
    "peerDependencies": {
        "@plurnk/plurnk-mimetypes": ">=0.11.0",
        "web-tree-sitter": "^0.25.0"
    }
}
